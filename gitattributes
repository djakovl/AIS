# Принудительно LF для всех текстовых файлов (кросс-платформенность)
* text=auto eol=lf

# Go
*.go text eol=lf
go.mod text eol=lf
go.sum text eol=lf

# Web
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf

# Config / Infrastructure
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
*.conf text eol=lf
*.env text eol=lf
*.md text eol=lf
Dockerfile text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Бинарные файлы — без конвертации
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.exe binary
